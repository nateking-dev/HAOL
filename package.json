{
  "name": "haol",
  "version": "0.2.0",
  "description": "Heterogeneous Agent Orchestration Layer",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "haol": "dist/bin/haol.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "seed:embeddings": "tsx src/cascade-router/seed-embeddings.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "dotenv": "^16.4.0",
    "hono": "^4.12.7",
    "mysql2": "^3.11.0",
    "safe-regex": "^2.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/safe-regex": "^1.1.6",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}
