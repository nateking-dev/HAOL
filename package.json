{
  "name": "haol",
  "version": "1.0.0",
  "description": "Heterogeneous Agent Orchestration Layer",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "haol": "dist/bin/haol.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "eslint .",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "seed:embeddings": "tsx src/cascade-router/seed-embeddings.ts",
    "demo:setup": "tsx scripts/demo-setup.ts",
    "load-test": "tsx scripts/load-test.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "npm audit --audit-level=moderate --omit=dev",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "dotenv": "^16.4.0",
    "hono": "^4.12.25",
    "mysql2": "^3.11.0",
    "pino": "^10.3.1",
    "safe-regex": "^2.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@types/safe-regex": "^1.1.6",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "prettier": "^3.8.1",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "esbuild": "~0.28.1"
  }
}
